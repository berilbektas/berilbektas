---
import { experiences } from '../data/experience';

const categoryColors: Record<string, string> = {
  research: 'bg-accent-lavender/20 text-accent-lavender',
  community: 'bg-accent-rose/20 text-accent-rose',
  content: 'bg-purple-300/15 text-purple-400/80',
  leadership: 'bg-amber-400/15 text-amber-600',
};
---

<section id="experience" class="timeline-section section-padding relative">
  <div class="max-w-6xl mx-auto">
    <div class="pixel-divider w-24 mb-6"></div>
    <h2 class="section-title font-display font-bold text-3xl md:text-4xl lg:text-5xl mb-16 tracking-tight">
      Experience<span class="gradient-text">.</span>
    </h2>

    <div class="relative">
      <!-- Timeline Line -->
      <div class="absolute left-4 lg:left-1/2 top-0 bottom-0 w-[1px] bg-text-primary/[0.06]">
        <div
          class="timeline-line-fill absolute top-0 left-0 w-full h-full origin-top scale-y-0"
          style="background: linear-gradient(180deg, #C48899, #D4A080);"
        ></div>
      </div>

      <!-- Timeline Items -->
      <div class="space-y-12 lg:space-y-16">
        {experiences.map((exp, i) => (
          <div class={`timeline-card relative flex flex-col lg:flex-row items-start gap-6 lg:gap-0 ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'}`}>
            <!-- Node (pixel heart) -->
            <div class="timeline-node absolute left-4 lg:left-1/2 -translate-x-1/2 mt-5 z-10">
              <svg width="14" height="13" viewBox="0 0 9 8" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering:pixelated;">
                <rect x="1" y="0" width="2" height="1" fill="#D8A0AC"/>
                <rect x="6" y="0" width="2" height="1" fill="#D8A0AC"/>
                <rect x="0" y="1" width="4" height="1" fill="#F0B8C0"/>
                <rect x="5" y="1" width="4" height="1" fill="#F0B8C0"/>
                <rect x="0" y="2" width="9" height="1" fill="#F0B8C0"/>
                <rect x="0" y="3" width="9" height="1" fill="#F0B8C0"/>
                <rect x="1" y="4" width="7" height="1" fill="#E8A0AC"/>
                <rect x="2" y="5" width="5" height="1" fill="#E8A0AC"/>
                <rect x="3" y="6" width="3" height="1" fill="#D8A0AC"/>
                <rect x="4" y="7" width="1" height="1" fill="#D8A0AC"/>
              </svg>
            </div>

            <!-- Card -->
            <div class={`ml-12 lg:ml-0 lg:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'lg:pr-0 lg:mr-auto' : 'lg:pl-0 lg:ml-auto'}`}>
              <div class="glass-card p-6 border-l-[3px] border-l-accent-lavender/40 hover:border-l-accent-lavender transition-all duration-300 hover:translate-y-[-4px]">
                <!-- Date & Location -->
                <div class="flex items-center gap-3 mb-3 flex-wrap">
                  <span class="text-text-muted font-pixel text-[7px]">{exp.date}</span>
                  <span class="text-text-muted text-xs">·</span>
                  <span class="text-text-muted text-xs">{exp.location}</span>
                </div>

                <!-- Title & Company -->
                <h3 class="font-display font-medium text-lg md:text-xl text-text-primary mb-1">
                  {exp.title}
                </h3>
                <p class="text-accent-lavender text-sm mb-3" style="font-weight:700;">{exp.company}</p>

                <!-- Category Badge -->
                <span class={`pixel-badge inline-block px-2.5 py-1.5 mb-4 ${categoryColors[exp.category]} border border-current/10`}>
                  {exp.category}
                </span>

                <!-- Description -->
                <p class="text-text-secondary text-sm leading-relaxed">{exp.description}</p>

                <!-- Highlights -->
                {exp.highlights && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {exp.highlights.map((h) => (
                      <span class="text-xs font-mono text-accent-rose bg-accent-rose/10 px-2.5 py-1 rounded">
                        {h}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
