---
import { socialLinks } from '../data/social';
import HeroPlatformScene from './HeroPlatformScene.astro';
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-6 bg-bg-secondary">
  <!-- Background gradient blobs -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute top-1/4 left-1/3 w-[600px] h-[600px] rounded-full animate-float opacity-[0.12]"
      style="background: radial-gradient(circle, #F3D0D7 0%, transparent 70%);"
      data-parallax="0.15"
    ></div>
    <div
      class="absolute bottom-1/3 right-1/4 w-[500px] h-[500px] rounded-full animate-float-delayed opacity-[0.10]"
      style="background: radial-gradient(circle, #D4A080 0%, transparent 70%);"
      data-parallax="0.1"
    ></div>
    <div
      class="absolute top-1/2 right-1/3 w-[300px] h-[300px] rounded-full animate-float opacity-[0.08]"
      style="background: radial-gradient(circle, #FFEFEF 0%, transparent 70%); animation-delay: -5s;"
    ></div>
    <div class="absolute inset-0 hero-grid opacity-[0.06]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center max-w-4xl mx-auto flex-1 flex flex-col items-center justify-center pt-12">
      <h1
        class="hero-name font-bold tracking-tight leading-[1.05] mb-3 hero-animate hero-delay-05 relative"
        style="font-family:'Caveat',cursive; font-size: clamp(2.8rem, 7vw + 1rem, 7rem);"
      >
        <span class="hero-name-text">Ber</span><span class="heart-i-wrap"><span class="hero-name-text">ı</span><span class="heart-dot">♥︎</span></span><span class="hero-name-text">l Bektas</span>
        <span class="sparkle sp-1" data-v="2">♥︎</span>
        <span class="sparkle sp-2" data-v="2">♥︎</span>
        <span class="sparkle sp-3" data-v="2">♥︎</span>
      </h1>

      <div class="hero-typewriter-wrap h-8 md:h-9 mb-4 hero-animate hero-delay-1 flex items-center justify-center">
        <p class="font-pixel text-text-secondary text-[10px] md:text-[12px] tracking-wide">
          <span id="typewriter" class="typewriter-text"></span>
          <span class="typewriter-cursor text-accent-lavender font-pixel text-sm">_</span>
        </p>
      </div>

      <div class="flex items-center justify-center gap-2 md:gap-3 mb-3 flex-wrap hero-animate hero-delay-2">
        <span class="hero-badge pixel-badge px-4 py-2.5">
          Research
        </span>
        <span class="text-[#D8A0AC]/30 font-pixel text-[6px] hidden md:inline">+</span>
        <span class="text-[#D8A0AC]/30 font-pixel text-[6px] md:hidden">+</span>
        <span class="hero-badge pixel-badge px-4 py-2.5">
          Content
        </span>
        <span class="text-[#D8A0AC]/30 font-pixel text-[6px] hidden md:inline">+</span>
        <span class="text-[#D8A0AC]/30 font-pixel text-[6px] md:hidden">+</span>
        <span class="hero-badge pixel-badge px-4 py-2.5">
          Community
        </span>
      </div>

      <div class="flex items-center justify-center gap-3 mt-5 hero-animate hero-delay-3">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-social w-11 h-11 rounded-[4px] flex items-center justify-center text-[#A08878] transition-all duration-300 hover:-translate-y-[2px] hover:text-[#806858]"
            style="background: rgba(190,170,155,0.14); border: 1px solid rgba(180,158,140,0.16); box-shadow: 0 2px 8px rgba(180,158,140,0.04), inset 0 1px 0 rgba(255,255,255,0.15);"
            aria-label={link.name}
            data-cursor-hover
          >
            <Fragment set:html={link.icon} />
          </a>
        ))}
      </div>

  </div>

  <!-- Scroll indicator - small animated arrow -->
  <div class="absolute z-20 left-1/2 -translate-x-1/2 flex flex-col items-center hero-animate hero-delay-3" style="bottom: 5%;">
    <svg class="scroll-arrow" width="16" height="10" viewBox="0 0 16 10" fill="none">
      <path d="M1 1L8 8L15 1" stroke="var(--accent-lavender)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
    </svg>
  </div>

  <HeroPlatformScene />
</section>

<style>
  .hero-badge {
    background: linear-gradient(135deg, rgba(216,160,172,0.10) 0%, rgba(196,136,153,0.16) 100%);
    color: #B07080;
    border: 1px solid rgba(196,136,153,0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 3px 14px rgba(196,136,153,0.10), 0 1px 4px rgba(196,136,153,0.06), inset 0 1px 0 rgba(255,255,255,0.25);
    font-size: 9px;
    transition: all 0.3s ease;
  }
  .hero-badge:hover {
    background: linear-gradient(135deg, rgba(216,160,172,0.18) 0%, rgba(196,136,153,0.24) 100%);
    border-color: rgba(196,136,153,0.28);
    box-shadow: 0 4px 16px rgba(196,136,153,0.10), inset 0 1px 0 rgba(255,255,255,0.3);
    transform: translateY(-2px);
  }

  .hero-grid {
    background-image:
      linear-gradient(rgba(196, 136, 153, 0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(196, 136, 153, 0.3) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .hero-name-text {
    color: #D8A0AC;
  }
  .heart-i-wrap {
    position: relative;
    display: inline-block;
  }
  .heart-dot {
    position: absolute;
    top: calc(0.82em + 28px);
    left: calc(70% + 11px);
    transform: translateX(-50%) rotate(-18deg);
    font-size: 0.16em;
    color: #D8A0AC;
    line-height: 1;
  }
  .sparkle {
    position: absolute;
    color: #D8A0AC;
    font-size: 0.075em;
    animation: sparkleAnim 2.8s ease-in-out infinite;
  }
  .sp-1 { top: 0.64em; right: -1.94em; animation-delay: 0s; }
  .sp-2 { top: 1.14em; right: -1.54em; animation-delay: 0.7s; }
  .sp-3 { top: 0.1em; left: 0.35em; animation-delay: 1.3s; }

  /* Mobile: hide sparkles to prevent text overflow clipping */
  /* Mobile: hide sparkles to prevent text overflow clipping */
  @media (max-width: 767px) {
    .sparkle { display: none; }
    .hero-name { font-size: clamp(2.2rem, 10vw, 3.5rem) !important; }
    .heart-dot {
      top: calc(0.82em + 10px) !important;
      left: calc(70% + 5px) !important;
    }
  }
  @keyframes sparkleAnim {
    0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    50% { opacity: 0.8; transform: scale(1) rotate(180deg); }
  }
  .hero-delay-05 { animation-delay: 0.15s; }
  .hero-delay-25 { animation-delay: 0.6s; }
  .typewriter-cursor { animation: cursorBlink 0.6s step-end infinite; }
  @keyframes cursorBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  .hero-social:hover {
    background: rgba(190,170,155,0.22) !important;
    border-color: rgba(180,158,140,0.28) !important;
    box-shadow: 0 4px 16px rgba(180,158,140,0.08), inset 0 1px 0 rgba(255,255,255,0.2) !important;
  }

  .scroll-arrow {
    animation: scrollBounce 2s ease-in-out infinite;
  }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50% { transform: translateY(5px); opacity: 0.7; }
  }
</style>

<script is:inline>
  (function() {
    var el = document.getElementById('typewriter');
    if (!el) return;
    var phrase = 'Making Web3 make sense.';
    var ci = 0, del = false;
    function tick() {
      if (!del) {
        el.textContent = phrase.substring(0, ci + 1);
        ci++;
        if (ci === phrase.length) { del = true; setTimeout(tick, 2500); return; }
        setTimeout(tick, 60 + Math.random() * 40);
      } else {
        el.textContent = phrase.substring(0, ci - 1);
        ci--;
        if (ci === 0) { del = false; setTimeout(tick, 400); return; }
        setTimeout(tick, 35);
      }
    }
    setTimeout(tick, 1200);
  })();
</script>
